.container {
  min-height: 100vh;
  background-color: #f8f9fa;
  padding-bottom: 120rpx;
  box-sizing: border-box;
}

/* 步骤指示器 */
.steps {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 40rpx 30rpx;
  background-color: #fff;
  box-shadow: 0 4rpx 10rpx rgba(0, 0, 0, 0.05);
  position: sticky;
  top: 0;
  z-index: 10;
}

.step {
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
  z-index: 2;
}

.step-num {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background-color: #e6e6e6;
  color: #999;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
  transition: all 0.3s;
}

.step-name {
  font-size: 24rpx;
  color: #999;
  transition: all 0.3s;
}

.step.active .step-num {
  background-color: #4a6bff;
  color: #fff;
}

.step.active .step-name {
  color: #4a6bff;
  font-weight: bold;
}

.step-line {
  flex: 1;
  height: 4rpx;
  background-color: #e6e6e6;
  position: relative;
  z-index: 1;
  transition: all 0.3s;
}

.step-line.active {
  background-color: #4a6bff;
}

/* 步骤内容 */
.step-content {
  height: calc(100vh - 280rpx);
}

.step-container {
  padding: 40rpx 30rpx;
}

.step-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 40rpx;
}

.form-item {
  margin-bottom: 30rpx;
}

.label {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 15rpx;
  display: flex;
  align-items: center;
}

.required {
  color: #ff4d4f;
  margin-left: 5rpx;
}

.sub-label {
  font-size: 24rpx;
  color: #999;
  margin-left: 10rpx;
  font-weight: normal;
}

.input {
  width: 100%;
  height: 88rpx;
  background-color: #f5f7fa;
  border-radius: 8rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.hint-text {
  font-size: 24rpx;
  color: #999;
  margin-top: 10rpx;
  line-height: 1.5;
}

.radio-group {
  display: flex;
  gap: 20rpx;
}

.radio {
  flex: 1;
  height: 88rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  background-color: #f5f7fa;
  border-radius: 8rpx;
  font-size: 28rpx;
  color: #666;
}

.radio.active {
  background-color: #e6edff;
  color: #4a6bff;
  font-weight: bold;
}

.tag-group {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.tag {
  padding: 10rpx 30rpx;
  background-color: #f5f7fa;
  border-radius: 30rpx;
  font-size: 26rpx;
  color: #666;
}

.tag.active {
  background-color: #e6edff;
  color: #4a6bff;
  font-weight: bold;
}

/* 五行元素标签样式 */
.element-tag {
  position: relative;
  padding-left: 50rpx;
}

.element-tag::before {
  content: '';
  position: absolute;
  left: 20rpx;
  top: 50%;
  transform: translateY(-50%);
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
}

.element-tag.jin::before {
  background-color: #f0f0f0;
}

.element-tag.mu::before {
  background-color: #a0d468;
}

.element-tag.shui::before {
  background-color: #5d9cec;
}

.element-tag.huo::before {
  background-color: #ed5565;
}

.element-tag.tu::before {
  background-color: #ffce54;
}

.element-tag.jin.active::before {
  background-color: #d9d9d9;
}

.element-tag.mu.active::before {
  background-color: #8cc152;
}

.element-tag.shui.active::before {
  background-color: #4a89dc;
}

.element-tag.huo.active::before {
  background-color: #da4453;
}

.element-tag.tu.active::before {
  background-color: #f6bb42;
}

.tip-box {
  margin-top: 40rpx;
  background-color: #fff8e6;
  border-radius: 8rpx;
  padding: 20rpx;
}

.tip-title {
  font-size: 26rpx;
  color: #faad14;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.tip-content {
  font-size: 24rpx;
  color: #999;
  line-height: 1.6;
}

.checkbox-item {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
  flex-wrap: wrap;
}

.checkbox-item text {
  margin-left: 10rpx;
  font-size: 28rpx;
  color: #666;
}

.checkbox-desc {
  margin-left: 10rpx;
  font-size: 24rpx !important;
  color: #999 !important;
  flex: 1;
  margin-left: 40rpx;
}

/* 底部按钮 */
.bottom-buttons {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 30rpx;
  background-color: #fff;
  box-shadow: 0 -4rpx 10rpx rgba(0, 0, 0, 0.05);
  display: flex;
  gap: 20rpx;
}

.btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: bold;
}

.btn-primary {
  background-color: #4a6bff;
  color: #fff;
}

.btn-primary[disabled] {
  background-color: #b3c0ff;
  color: #fff;
}

.btn-outline {
  background-color: transparent;
  border: 2rpx solid #4a6bff;
  color: #4a6bff;
}

.picker {
  width: 100%;
}
