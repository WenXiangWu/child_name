/**
 * 全局样式
 */

/* 主题颜色 */
page {
  --primary-color: #4a6bff;
  --primary-light: #e6edff;
  --primary-gradient: linear-gradient(to right, #4a6bff, #6b8dff);
  --secondary-color: #ff6b6b;
  --secondary-light: #ffe6e6;
  --text-color: #333333;
  --text-color-light: #666666;
  --text-color-lighter: #999999;
  --background-color: #f8f9fa;
  --card-background: #ffffff;
  --border-color: #eeeeee;
  --success-color: #52c41a;
  --warning-color: #faad14;
  --error-color: #f5222d;

  /* 字体设置 */
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, 'Noto Sans', sans-serif, 'Apple Color Emoji', 'Segoe UI Emoji', 'Segoe UI Symbol', 'Noto Color Emoji';
  font-size: 28rpx;
  line-height: 1.5;
  color: var(--text-color);
  background-color: var(--background-color);
}

/* 通用容器 */
.container {
  min-height: 100vh;
  box-sizing: border-box;
}

/* 卡片样式 */
.card {
  background-color: var(--card-background);
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

/* 标题样式 */
.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--text-color);
}

.section-more {
  font-size: 24rpx;
  color: var(--primary-color);
}

/* 按钮样式 */
.btn {
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: bold;
  padding: 0 40rpx;
}

.btn-primary {
  background-color: var(--primary-color);
  color: #fff;
}

.btn-secondary {
  background-color: var(--secondary-color);
  color: #fff;
}

.btn-outline {
  background-color: transparent;
  border: 2rpx solid var(--primary-color);
  color: var(--primary-color);
}

.btn:active {
  opacity: 0.9;
}

/* 表单样式 */
.form-item {
  margin-bottom: 20rpx;
}

.label {
  display: block;
  font-size: 28rpx;
  color: var(--text-color-light);
  margin-bottom: 10rpx;
}

.input {
  width: 100%;
  height: 80rpx;
  background-color: #f5f7fa;
  border-radius: 8rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

/* 标签样式 */
.tag {
  display: inline-block;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  margin-right: 12rpx;
}

.tag-primary {
  background-color: var(--primary-light);
  color: var(--primary-color);
}

.tag-secondary {
  background-color: var(--secondary-light);
  color: var(--secondary-color);
}

/* 分割线 */
.divider {
  height: 1rpx;
  background-color: var(--border-color);
  margin: 20rpx 0;
}
