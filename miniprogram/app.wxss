/* app.wxss */

/* 字体图标样式 - 使用Unicode字符 */
.iconfont {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto', 'Oxygen', 'Ubuntu', 'Cantarell', 'Fira Sans', 'Droid Sans', 'Helvetica Neue', sans-serif;
  font-size: 16px;
  font-style: normal;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}

/* 图标类名 - 使用Unicode Emoji */
.icon-home:before { content: "🏠"; }
.icon-snake:before { content: "🐍"; }
.icon-bagua:before { content: "☯️"; }
.icon-book:before { content: "📚"; }
.icon-scroll:before { content: "📜"; }
.icon-search:before { content: "🔍"; }
.icon-radical:before { content: "🔤"; }
.icon-stroke:before { content: "✍️"; }
.icon-house:before { content: "🏡"; }
.icon-poem:before { content: "📖"; }
.icon-user:before { content: "👤"; }
.icon-find:before { content: "🔎"; }
.icon-char:before { content: "🔠"; }
.icon-poetry:before { content: "📝"; }
.icon-my:before { content: "👨"; }

/* 全局样式 */
page {
  background-color: #f8f9fa;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto', 'Oxygen', 'Ubuntu', 'Cantarell', 'Fira Sans', 'Droid Sans', 'Helvetica Neue', sans-serif;
}

/* 通用图标样式 */
.icon {
  font-family: "iconfont" !important;
  font-size: 16px;
  font-style: normal;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}

/* 自定义图标大小 */
.icon-sm { font-size: 24rpx; }
.icon-md { font-size: 32rpx; }
.icon-lg { font-size: 48rpx; }
.icon-xl { font-size: 64rpx; }

.container {
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
  padding: 20rpx;
}

.btn-primary {
  background-color: #4a6bff;
  color: #fff;
  border-radius: 8rpx;
}

.btn-default {
  background-color: #f2f2f2;
  color: #333;
  border-radius: 8rpx;
}

.card {
  background-color: #fff;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.text-center {
  text-align: center;
}

.text-primary {
  color: #4a6bff;
}

.text-secondary {
  color: #666;
}

.text-small {
  font-size: 12px;
}

.mt-10 {
  margin-top: 10rpx;
}

.mb-10 {
  margin-bottom: 10rpx;
}

.mt-20 {
  margin-top: 20rpx;
}

.mb-20 {
  margin-bottom: 20rpx;
}

.flex-row {
  display: flex;
  flex-direction: row;
}

.flex-column {
  display: flex;
  flex-direction: column;
}

.flex-wrap {
  flex-wrap: wrap;
}

.justify-between {
  justify-content: space-between;
}

.justify-center {
  justify-content: center;
}

.align-center {
  align-items: center;
}

.flex-1 {
  flex: 1;
}
