/* index.wxss */
.container {
  min-height: 100vh;
  background:
    radial-gradient(circle at 20% 20%, rgba(255, 215, 0, 0.1) 0%, transparent 50%),
    radial-gradient(circle at 80% 80%, rgba(139, 69, 19, 0.1) 0%, transparent 50%),
    radial-gradient(circle at 40% 70%, rgba(160, 82, 45, 0.08) 0%, transparent 50%),
    linear-gradient(135deg, #faf7f2 0%, #f5e6d3 25%, #e8d5c0 50%, #dcc4a8 75%, #d4b896 100%);
  padding: 0;
  position: relative;
  overflow-x: hidden;
}

/* 全局装饰背景 */
.container::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background:
    url('data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100"><defs><pattern id="grain" width="100" height="100" patternUnits="userSpaceOnUse"><circle cx="20" cy="20" r="1" fill="rgba(139,69,19,0.02)"/><circle cx="80" cy="40" r="1" fill="rgba(160,82,45,0.02)"/><circle cx="40" cy="80" r="1" fill="rgba(139,69,19,0.015)"/><circle cx="60" cy="10" r="1" fill="rgba(160,82,45,0.015)"/><circle cx="10" cy="60" r="1" fill="rgba(139,69,19,0.02)"/></pattern></defs><rect width="100" height="100" fill="url(%23grain)"/></svg>') repeat;
  opacity: 0.3;
  z-index: 1;
  pointer-events: none;
}

/* 动态背景装饰 */
.container::after {
  content: '';
  position: absolute;
  top: -50%;
  left: -50%;
  width: 200%;
  height: 200%;
  background:
    radial-gradient(circle at 30% 30%, rgba(255, 215, 0, 0.05) 0%, transparent 30%),
    radial-gradient(circle at 70% 70%, rgba(139, 69, 19, 0.05) 0%, transparent 30%);
  animation: backgroundMove 20s ease-in-out infinite;
  z-index: 1;
  pointer-events: none;
}

@keyframes backgroundMove {
  0%, 100% { transform: translate(0, 0) rotate(0deg); }
  33% { transform: translate(-10px, -10px) rotate(1deg); }
  66% { transform: translate(10px, -5px) rotate(-1deg); }
}

/* 顶部品牌区域 - 优化间距 */
.header-section {
  position: relative;
  padding: 40rpx 0 30rpx;
  overflow: hidden;
  z-index: 10;
}

.header-section::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background:
    linear-gradient(135deg, rgba(255, 255, 255, 0.8) 0%, rgba(255, 255, 255, 0.4) 100%);
  backdrop-filter: blur(20rpx);
  z-index: 2;
}

.brand-container {
  position: relative;
  z-index: 10;
}

/* 装饰性背景元素 */
.brand-decoration {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 1;
  pointer-events: none;
}

.deco-circle {
  position: absolute;
  border-radius: 50%;
  background:
    radial-gradient(circle at 30% 30%, rgba(255, 215, 0, 0.15), rgba(139, 69, 19, 0.1));
  box-shadow:
    0 0 30rpx rgba(255, 215, 0, 0.2),
    inset 0 0 20rpx rgba(255, 255, 255, 0.3);
  animation: float 6s ease-in-out infinite;
}

.deco-circle-1 {
  width: 120rpx;
  height: 120rpx;
  top: 10rpx;
  left: 40rpx;
  animation-delay: 0s;
}

.deco-circle-2 {
  width: 80rpx;
  height: 80rpx;
  top: 20rpx;
  right: 30rpx;
  animation-delay: 2s;
}

.deco-circle-3 {
  width: 100rpx;
  height: 100rpx;
  bottom: 40rpx;
  left: 50%;
  transform: translateX(-50%);
  animation-delay: 4s;
}

@keyframes float {
  0%, 100% { transform: translateY(0px) scale(1); }
  50% { transform: translateY(-15px) scale(1.05); }
}

@keyframes pulse {
  0% { transform: scale(1); }
  50% { transform: scale(1.08); }
  100% { transform: scale(1); }
}

@keyframes shimmer {
  0% { opacity: 0.6; }
  50% { opacity: 1; }
  100% { opacity: 0.6; }
}

/* 主品牌标识 - 优化间距 */
.brand-main {
  position: relative;
  z-index: 5;
  text-align: center;
  margin-bottom: 30rpx;
}

.brand-icon-container {
  position: relative;
  display: inline-block;
  margin-bottom: 25rpx;
}

.brand-icon-bg {
  position: absolute;
  top: -10rpx;
  left: -10rpx;
  width: 120rpx;
  height: 120rpx;
  background:
    radial-gradient(circle at 30% 30%, rgba(255, 215, 0, 0.2), rgba(139, 69, 19, 0.1));
  border-radius: 50%;
  z-index: 1;
  animation: shimmer 3s ease-in-out infinite;
  filter: blur(2rpx);
}

.brand-icon {
  position: relative;
  width: 100rpx;
  height: 100rpx;
  background:
    linear-gradient(135deg, rgba(255, 255, 255, 0.1) 0%, rgba(255, 255, 255, 0.05) 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow:
    0 8rpx 24rpx rgba(139, 69, 19, 0.4),
    0 4rpx 12rpx rgba(139, 69, 19, 0.3),
    inset 0 2rpx 4rpx rgba(255, 255, 255, 0.3),
    inset 0 -2rpx 4rpx rgba(0, 0, 0, 0.1);
  z-index: 3;
  transition: all 0.4s ease;
  animation: pulse 5s ease-in-out infinite;
  border: 2rpx solid rgba(255, 255, 255, 0.2);
}

.brand-icon:hover {
  transform: translateY(-4rpx) scale(1.05);
  box-shadow:
    0 12rpx 32rpx rgba(139, 69, 19, 0.5),
    0 6rpx 16rpx rgba(139, 69, 19, 0.4),
    inset 0 2rpx 4rpx rgba(255, 255, 255, 0.4),
    inset 0 -2rpx 4rpx rgba(0, 0, 0, 0.2);
  animation-play-state: paused;
}

.logo-image {
  width: 80rpx;
  height: 80rpx;
  filter: drop-shadow(0 2rpx 4rpx rgba(0, 0, 0, 0.2));
}

.logo-text {
  font-size: 54rpx;
  font-weight: 900;
  color: white;
  text-shadow:
    0 3rpx 6rpx rgba(0, 0, 0, 0.4),
    0 1rpx 2rpx rgba(0, 0, 0, 0.3);
  display: none;
}

.brand-icon-shadow {
  position: absolute;
  top: 8rpx;
  left: 8rpx;
  width: 100rpx;
  height: 100rpx;
  background:
    radial-gradient(circle at 30% 30%, rgba(139, 69, 19, 0.3), rgba(139, 69, 19, 0.1));
  border-radius: 50%;
  z-index: 2;
  filter: blur(6rpx);
}

.brand-icon .iconfont {
  font-size: 54rpx;
  color: white;
  text-shadow:
    0 3rpx 6rpx rgba(0, 0, 0, 0.4),
    0 1rpx 2rpx rgba(0, 0, 0, 0.3);
}

.brand-text-container {
  text-align: center;
}

.brand-name {
  font-size: 80rpx;
  font-weight: 900;
  background: linear-gradient(135deg, #d4af37 0%, #8b4513 50%, #a0522d 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  text-shadow:
    0 4rpx 8rpx rgba(139, 69, 19, 0.3),
    0 2rpx 4rpx rgba(139, 69, 19, 0.2);
  letter-spacing: 12rpx;
  display: block;
  margin-bottom: 20rpx;
  filter: drop-shadow(0 2rpx 4rpx rgba(139, 69, 19, 0.2));
}

.brand-subtitle-container {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 10rpx;
}

.subtitle-line {
  width: 40rpx;
  height: 2rpx;
  background: linear-gradient(90deg, transparent, #d4af37, #8b4513, transparent);
  margin: 0 15rpx;
  box-shadow: 0 1rpx 2rpx rgba(139, 69, 19, 0.2);
}

.brand-subtitle {
  font-size: 22rpx;
  color: white;
  background: linear-gradient(135deg, #d4af37 0%, #8b4513 50%, #a0522d 100%);
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
  box-shadow:
    0 3rpx 8rpx rgba(139, 69, 19, 0.4),
    inset 0 1rpx 2rpx rgba(255, 255, 255, 0.3);
  border: 1rpx solid rgba(255, 255, 255, 0.2);
}

/* 品牌理念 - 优化间距 */
.brand-philosophy {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 30rpx;
  position: relative;
  z-index: 5;
}

.philosophy-ornament {
  display: flex;
  align-items: center;
  margin: 0 25rpx;
}

.ornament-dot {
  width: 8rpx;
  height: 8rpx;
  background:
    radial-gradient(circle at 30% 30%, #d4af37, #8b4513);
  border-radius: 50%;
  margin: 0 6rpx;
  animation: shimmer 2s ease-in-out infinite;
  box-shadow: 0 1rpx 2rpx rgba(139, 69, 19, 0.3);
}

.ornament-line {
  width: 40rpx;
  height: 2rpx;
  background: linear-gradient(90deg, #d4af37, #8b4513, #a0522d);
  box-shadow: 0 1rpx 2rpx rgba(139, 69, 19, 0.2);
}

.philosophy-text {
  font-size: 30rpx;
  background: linear-gradient(135deg, #8b4513 0%, #a0522d 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  font-weight: 700;
  letter-spacing: 4rpx;
  text-shadow: 0 2rpx 4rpx rgba(139, 69, 19, 0.1);
  position: relative;
  filter: drop-shadow(0 1rpx 2rpx rgba(139, 69, 19, 0.2));
}

.philosophy-text::before {
  content: '';
  position: absolute;
  bottom: -4rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 60rpx;
  height: 2rpx;
  background: linear-gradient(90deg, transparent, #d4af37, #8b4513, transparent);
  box-shadow: 0 1rpx 2rpx rgba(139, 69, 19, 0.2);
}

/* 品质标识 - 优化间距 */
.quality-badges {
  display: flex;
  justify-content: center;
  gap: 20rpx;
  position: relative;
  z-index: 5;
}

.badge {
  background:
    linear-gradient(135deg, rgba(255, 255, 255, 0.9) 0%, rgba(255, 255, 255, 0.7) 100%);
  border: 2rpx solid rgba(212, 175, 55, 0.3);
  border-radius: 20rpx;
  padding: 8rpx 20rpx;
  box-shadow:
    0 3rpx 8rpx rgba(139, 69, 19, 0.15),
    inset 0 1rpx 2rpx rgba(255, 255, 255, 0.5);
  backdrop-filter: blur(20rpx);
  transition: all 0.4s ease;
  position: relative;
  overflow: hidden;
}

.badge::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(212, 175, 55, 0.2), transparent);
  transition: left 0.6s ease;
}

.badge:hover::before {
  left: 100%;
}

.badge:hover {
  transform: translateY(-2rpx);
  box-shadow:
    0 6rpx 16rpx rgba(139, 69, 19, 0.25),
    inset 0 1rpx 2rpx rgba(255, 255, 255, 0.6);
  background:
    linear-gradient(135deg, rgba(255, 255, 255, 0.95) 0%, rgba(255, 255, 255, 0.8) 100%);
  border-color: rgba(212, 175, 55, 0.5);
}

.badge-text {
  font-size: 22rpx;
  background: linear-gradient(135deg, #8b4513 0%, #a0522d 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  font-weight: 700;
  letter-spacing: 2rpx;
  position: relative;
  z-index: 2;
}

/* 功能卡片通用样式优化 - 减少间距 */
.main-functions,
.auxiliary-functions,
.quick-naming-section,
.dictionary-section {
  margin: 0 30rpx 30rpx;
  background:
    linear-gradient(135deg, rgba(255, 255, 255, 0.9) 0%, rgba(255, 255, 255, 0.7) 100%);
  border-radius: 20rpx;
  box-shadow:
    0 8rpx 24rpx rgba(139, 69, 19, 0.15),
    0 4rpx 12rpx rgba(139, 69, 19, 0.1),
    inset 0 1rpx 2rpx rgba(255, 255, 255, 0.5);
  backdrop-filter: blur(20rpx);
  border: 1rpx solid rgba(255, 255, 255, 0.3);
  position: relative;
  overflow: hidden;
}

.main-functions::before,
.auxiliary-functions::before,
.quick-naming-section::before,
.dictionary-section::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 2rpx;
  background: linear-gradient(90deg, transparent, rgba(212, 175, 55, 0.3), transparent);
}

/* 主功能区 - 优化间距 */
.main-functions {
  display: flex;
  justify-content: space-around;
  padding: 40rpx 20rpx;
}

.function-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
  transition: all 0.3s ease;
}

.function-item:active {
  transform: scale(0.95);
}

.function-icon {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
  box-shadow:
    0 6rpx 18rpx rgba(0, 0, 0, 0.15),
    inset 0 1rpx 2rpx rgba(255, 255, 255, 0.3);
  transition: all 0.3s ease;
  border: 2rpx solid rgba(255, 255, 255, 0.2);
}

.function-icon:hover {
  transform: translateY(-3rpx);
  box-shadow:
    0 8rpx 24rpx rgba(0, 0, 0, 0.2),
    inset 0 1rpx 2rpx rgba(255, 255, 255, 0.4);
}

.snake-icon {
  background: linear-gradient(135deg, #4a5568 0%, #2d3748 100%);
}

.bagua-icon {
  background: linear-gradient(135deg, #d4af37 0%, #8b4513 100%);
}

.book-icon {
  background: linear-gradient(135deg, #2f855a 0%, #38a169 100%);
}

.scroll-icon {
  background: linear-gradient(135deg, #2b6cb0 0%, #3182ce 100%);
}

.function-icon .iconfont {
  font-size: 54rpx;
  color: white;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.3);
}

.function-text {
  font-size: 26rpx;
  color: #8b4513;
  font-weight: 600;
  letter-spacing: 1rpx;
}

/* 快速起名区 - 优化间距 */
.quick-naming-section {
  padding: 40rpx 30rpx;
}

.input-row {
  display: flex;
  align-items: center;
  margin-bottom: 30rpx;
}

.input-group {
  flex: 1;
  display: flex;
  align-items: center;
}

.input-label {
  font-size: 30rpx;
  color: #8b4513;
  margin-right: 20rpx;
  font-weight: 600;
}

.name-input {
  flex: 1;
  height: 80rpx;
  border: 2rpx solid rgba(139, 69, 19, 0.2);
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  background: rgba(255, 255, 255, 0.8);
  transition: all 0.3s ease;
  box-shadow: inset 0 1rpx 2rpx rgba(0, 0, 0, 0.05);
}

.name-input:focus {
  border-color: #d4af37;
  box-shadow:
    0 0 0 3rpx rgba(212, 175, 55, 0.2),
    inset 0 1rpx 2rpx rgba(0, 0, 0, 0.05);
}

.gender-group {
  display: flex;
  margin-left: 30rpx;
}

.gender-option {
  width: 80rpx;
  height: 60rpx;
  border: 2rpx solid rgba(139, 69, 19, 0.2);
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: 15rpx;
  font-size: 26rpx;
  color: #666;
  background: rgba(255, 255, 255, 0.8);
  transition: all 0.3s ease;
  cursor: pointer;
  box-shadow: inset 0 1rpx 2rpx rgba(0, 0, 0, 0.05);
}

.gender-option:active {
  transform: scale(0.95);
}

.gender-option.selected {
  border-color: #d4af37;
  background: linear-gradient(135deg, #d4af37 0%, #8b4513 100%);
  color: white;
  box-shadow:
    0 3rpx 8rpx rgba(212, 175, 55, 0.3),
    inset 0 1rpx 2rpx rgba(255, 255, 255, 0.2);
}

.search-button {
  width: 100%;
  height: 80rpx;
  background: linear-gradient(135deg, #d4af37 0%, #8b4513 50%, #a0522d 100%);
  color: white;
  border: none;
  border-radius: 12rpx;
  font-size: 32rpx;
  font-weight: 700;
  box-shadow:
    0 4rpx 12rpx rgba(139, 69, 19, 0.4),
    inset 0 1rpx 2rpx rgba(255, 255, 255, 0.2);
  transition: all 0.3s ease;
  letter-spacing: 2rpx;
}

.search-button:active {
  transform: translateY(1rpx);
  box-shadow:
    0 3rpx 8rpx rgba(139, 69, 19, 0.4),
    inset 0 1rpx 2rpx rgba(255, 255, 255, 0.2);
}

/* 辅助功能区 - 优化间距 */
.auxiliary-functions {
  display: flex;
  justify-content: space-around;
  padding: 40rpx 20rpx;
}

.aux-function-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
  transition: transform 0.3s ease;
}

.aux-function-item:active {
  transform: scale(0.95);
}

.aux-function-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background:
    linear-gradient(135deg, rgba(212, 175, 55, 0.15) 0%, rgba(139, 69, 19, 0.1) 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 15rpx;
  transition: all 0.3s ease;
  box-shadow:
    0 3rpx 8rpx rgba(139, 69, 19, 0.1),
    inset 0 1rpx 2rpx rgba(255, 255, 255, 0.3);
}

.aux-function-icon:hover {
  background:
    linear-gradient(135deg, rgba(212, 175, 55, 0.2) 0%, rgba(139, 69, 19, 0.15) 100%);
  transform: translateY(-2rpx);
  box-shadow:
    0 4rpx 12rpx rgba(139, 69, 19, 0.15),
    inset 0 1rpx 2rpx rgba(255, 255, 255, 0.4);
}

.aux-function-icon .iconfont {
  font-size: 36rpx;
  color: #8b4513;
}

.aux-function-text {
  font-size: 24rpx;
  color: #8b4513;
  font-weight: 600;
}

/* 字典查询区 - 优化间距 */
.dictionary-section {
  padding: 40rpx 30rpx;
}

.dictionary-input-row {
  display: flex;
  align-items: center;
}

.dictionary-input {
  flex: 1;
  height: 80rpx;
  border: 2rpx solid rgba(139, 69, 19, 0.2);
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  background: rgba(255, 255, 255, 0.8);
  margin-right: 20rpx;
  transition: all 0.3s ease;
  box-shadow: inset 0 1rpx 2rpx rgba(0, 0, 0, 0.05);
}

.dictionary-input:focus {
  border-color: #d4af37;
  box-shadow:
    0 0 0 3rpx rgba(212, 175, 55, 0.2),
    inset 0 1rpx 2rpx rgba(0, 0, 0, 0.05);
}

.dictionary-button {
  width: 160rpx;
  height: 80rpx;
  background: linear-gradient(135deg, #d4af37 0%, #8b4513 50%, #a0522d 100%);
  color: white;
  border: none;
  border-radius: 12rpx;
  font-size: 26rpx;
  font-weight: 700;
  box-shadow:
    0 4rpx 12rpx rgba(139, 69, 19, 0.4),
    inset 0 1rpx 2rpx rgba(255, 255, 255, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  transition: all 0.3s ease;
}

.dictionary-button:active {
  transform: translateY(1rpx);
  box-shadow:
    0 3rpx 8rpx rgba(139, 69, 19, 0.4),
    inset 0 1rpx 2rpx rgba(255, 255, 255, 0.2);
}

.dictionary-button .iconfont {
  font-size: 24rpx;
}
