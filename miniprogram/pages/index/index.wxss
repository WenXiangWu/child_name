/* index.wxss */
.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #f5e6d3 0%, #e8d5c0 100%);
  padding: 0;
  position: relative;
}

/* 顶部品牌区域 */
.header-section {
  text-align: center;
  padding: 40rpx 0 60rpx;
  position: relative;
}

.brand-logo {
  position: relative;
  margin-bottom: 30rpx;
}

.brand-bg {
  width: 120rpx;
  height: 120rpx;
  opacity: 0.3;
}

.brand-text {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  z-index: 2;
}

.brand-name {
  font-size: 72rpx;
  font-weight: bold;
  color: #8b4513;
  text-shadow: 2rpx 2rpx 4rpx rgba(139, 69, 19, 0.3);
  letter-spacing: 8rpx;
  display: block;
  margin-bottom: 10rpx;
}

.brand-subtitle {
  font-size: 24rpx;
  color: #d2691e;
  background: #8b4513;
  color: white;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
  font-weight: 500;
}

.brand-slogan {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
}

.slogan-line {
  width: 60rpx;
  height: 2rpx;
  background: #8b4513;
  margin: 0 20rpx;
}

.slogan-text {
  font-size: 28rpx;
  color: #8b4513;
  font-weight: 500;
  letter-spacing: 2rpx;
}

/* 主功能区 */
.main-functions {
  display: flex;
  justify-content: space-around;
  padding: 40rpx 30rpx;
  margin: 0 30rpx 40rpx;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 20rpx;
  box-shadow: 0 8rpx 24rpx rgba(139, 69, 19, 0.1);
}

.function-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.function-icon {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.snake-icon {
  background: linear-gradient(135deg, #4a5568, #2d3748);
}

.bagua-icon {
  background: linear-gradient(135deg, #8b4513, #a0522d);
}

.book-icon {
  background: linear-gradient(135deg, #2f855a, #38a169);
}

.scroll-icon {
  background: linear-gradient(135deg, #2b6cb0, #3182ce);
}

.function-icon image {
  width: 60rpx;
  height: 60rpx;
}

.function-text {
  font-size: 28rpx;
  color: #8b4513;
  font-weight: 500;
}

/* 快速起名区 */
.quick-naming-section {
  margin: 0 30rpx 40rpx;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 20rpx;
  padding: 40rpx;
  box-shadow: 0 8rpx 24rpx rgba(139, 69, 19, 0.1);
}

.input-row {
  display: flex;
  align-items: center;
  margin-bottom: 30rpx;
}

.input-group {
  flex: 1;
  display: flex;
  align-items: center;
}

.input-label {
  font-size: 32rpx;
  color: #8b4513;
  margin-right: 20rpx;
  font-weight: 500;
}

.name-input {
  flex: 1;
  height: 80rpx;
  border: 2rpx solid #ddd;
  border-radius: 10rpx;
  padding: 0 20rpx;
  font-size: 30rpx;
  background: white;
}

.gender-group {
  display: flex;
  margin-left: 40rpx;
}

.gender-option {
  width: 80rpx;
  height: 60rpx;
  border: 2rpx solid #ddd;
  border-radius: 10rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: 20rpx;
  font-size: 28rpx;
  color: #666;
  background: white;
}

.gender-option.selected {
  border-color: #8b4513;
  background: #8b4513;
  color: white;
}

.search-button {
  width: 100%;
  height: 80rpx;
  background: linear-gradient(135deg, #8b4513, #a0522d);
  color: white;
  border: none;
  border-radius: 10rpx;
  font-size: 32rpx;
  font-weight: 500;
  box-shadow: 0 4rpx 12rpx rgba(139, 69, 19, 0.3);
}

/* 辅助功能区 */
.auxiliary-functions {
  display: flex;
  justify-content: space-around;
  padding: 40rpx 30rpx;
  margin: 0 30rpx 40rpx;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 20rpx;
  box-shadow: 0 8rpx 24rpx rgba(139, 69, 19, 0.1);
}

.aux-function-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.aux-function-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: rgba(139, 69, 19, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 15rpx;
}

.aux-function-icon image {
  width: 40rpx;
  height: 40rpx;
}

.aux-function-text {
  font-size: 24rpx;
  color: #8b4513;
}

/* 字典查询区 */
.dictionary-section {
  margin: 0 30rpx 40rpx;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 20rpx;
  padding: 40rpx;
  box-shadow: 0 8rpx 24rpx rgba(139, 69, 19, 0.1);
}

.dictionary-input-row {
  display: flex;
  align-items: center;
}

.dictionary-input {
  flex: 1;
  height: 80rpx;
  border: 2rpx solid #ddd;
  border-radius: 10rpx;
  padding: 0 20rpx;
  font-size: 30rpx;
  background: white;
  margin-right: 20rpx;
}

.dictionary-button {
  width: 160rpx;
  height: 80rpx;
  background: linear-gradient(135deg, #8b4513, #a0522d);
  color: white;
  border: none;
  border-radius: 10rpx;
  font-size: 28rpx;
  font-weight: 500;
  box-shadow: 0 4rpx 12rpx rgba(139, 69, 19, 0.3);
}
