<view class="container">
  <view class="user-card">
    <view class="user-avatar">
      <open-data type="userAvatarUrl"></open-data>
    </view>
    <view class="user-info">
      <view class="user-name">
        <open-data type="userNickName"></open-data>
      </view>
      <view class="user-desc">欢迎使用起名助手</view>
    </view>
  </view>

  <view class="menu-list">
    <navigator url="/pages/history/index" class="menu-item">
      <image class="menu-icon" src="/images/icon-history.png"></image>
      <view class="menu-text">历史记录</view>
      <view class="menu-arrow"></view>
    </navigator>

    <view class="menu-item" bindtap="viewFavorites">
      <image class="menu-icon" src="/images/icon-favorite.png"></image>
      <view class="menu-text">我的收藏</view>
      <view class="menu-arrow"></view>
    </view>

    <button class="menu-item" open-type="share">
      <image class="menu-icon" src="/images/icon-share.png"></image>
      <view class="menu-text">分享给好友</view>
      <view class="menu-arrow"></view>
    </button>

    <button class="menu-item" open-type="contact">
      <image class="menu-icon" src="/images/icon-feedback.png"></image>
      <view class="menu-text">意见反馈</view>
      <view class="menu-arrow"></view>
    </button>

    <view class="menu-item" bindtap="clearCache">
      <image class="menu-icon" src="/images/icon-clear.png"></image>
      <view class="menu-text">清除缓存</view>
      <view class="menu-arrow"></view>
    </view>
  </view>

  <view class="about-section">
    <view class="about-title">关于起名助手</view>
    <view class="about-text">起名助手是一款专业的中文起名工具，提供基于五行、音律、字义等多维度的智能起名服务。</view>
    <view class="version">版本号：1.0.0</view>
  </view>
</view>
