.container {
  min-height: 100vh;
  background-color: #f8f9fa;
  padding-bottom: 30rpx;
  box-sizing: border-box;
}

/* 搜索区域 */
.search-area {
  background-color: #fff;
  padding: 20rpx 30rpx 0;
  box-shadow: 0 4rpx 10rpx rgba(0, 0, 0, 0.05);
  position: sticky;
  top: 0;
  z-index: 10;
}

.search-bar {
  display: flex;
  height: 80rpx;
  background-color: #f5f7fa;
  border-radius: 40rpx;
  padding: 0 20rpx;
  margin-bottom: 20rpx;
}

.search-input {
  flex: 1;
  height: 100%;
  font-size: 28rpx;
}

.search-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 60rpx;
}

.search-icon {
  width: 36rpx;
  height: 36rpx;
  opacity: 0.6;
}

.search-tabs {
  display: flex;
  border-bottom: 1rpx solid #eee;
}

.tab {
  flex: 1;
  text-align: center;
  font-size: 28rpx;
  color: #666;
  padding: 20rpx 0;
  position: relative;
}

.tab.active {
  color: #4a6bff;
  font-weight: bold;
}

.tab.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 6rpx;
  background-color: #4a6bff;
  border-radius: 3rpx;
}

/* 内容区域 */
.content-swiper {
  height: 400rpx;
}

/* 拼音搜索 */
.pinyin-container {
  height: 100%;
  padding: 20rpx 30rpx;
}

.pinyin-groups {
  display: flex;
  flex-direction: column;
}

.pinyin-group {
  margin-bottom: 30rpx;
}

.group-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 15rpx;
}

.pinyin-list {
  display: flex;
  flex-wrap: wrap;
  gap: 15rpx;
}

.pinyin-item {
  width: 80rpx;
  height: 60rpx;
  background-color: #f5f7fa;
  border-radius: 8rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 26rpx;
  color: #666;
}

.pinyin-item.active {
  background-color: #e6edff;
  color: #4a6bff;
  font-weight: bold;
}

/* 部首搜索 */
.radical-container {
  height: 100%;
  padding: 20rpx 30rpx;
}

.radical-groups {
  display: flex;
  flex-direction: column;
}

.radical-group {
  margin-bottom: 30rpx;
}

.radical-list {
  display: flex;
  flex-wrap: wrap;
  gap: 15rpx;
}

.radical-item {
  width: 60rpx;
  height: 60rpx;
  background-color: #f5f7fa;
  border-radius: 8rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 28rpx;
  color: #666;
}

.radical-item.active {
  background-color: #e6edff;
  color: #4a6bff;
  font-weight: bold;
}

/* 笔画搜索 */
.stroke-container {
  height: 100%;
  padding: 30rpx;
}

.stroke-count {
  margin-bottom: 40rpx;
}

.count-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.count-slider {
  margin: 0;
}

.stroke-range {
  margin-top: 60rpx;
}

.range-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.range-inputs {
  display: flex;
  align-items: center;
  margin-bottom: 30rpx;
}

.range-input {
  width: 120rpx;
  height: 80rpx;
  background-color: #f5f7fa;
  border-radius: 8rpx;
  text-align: center;
  font-size: 28rpx;
}

.range-separator {
  margin: 0 20rpx;
  color: #999;
}

.range-btn {
  width: 200rpx;
  height: 80rpx;
  line-height: 80rpx;
  background-color: #4a6bff;
  color: #fff;
  font-size: 28rpx;
  border-radius: 40rpx;
}

/* 五行搜索 */
.five-elements-container {
  height: 100%;
  padding: 30rpx;
  display: flex;
  justify-content: center;
  align-items: center;
}

.element-list {
  display: flex;
  justify-content: space-around;
  width: 100%;
}

.element-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx;
  border-radius: 16rpx;
  transition: all 0.3s;
}

.element-item.active {
  background-color: #f5f8ff;
}

.element-circle {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 40rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 15rpx;
}

.element-circle.jin {
  background-color: #FFD700;
}

.element-circle.mu {
  background-color: #2E8B57;
}

.element-circle.shui {
  background-color: #1E90FF;
}

.element-circle.huo {
  background-color: #FF4500;
}

.element-circle.tu {
  background-color: #8B4513;
}

.element-name {
  font-size: 28rpx;
  color: #333;
}

/* 搜索结果 */
.search-results {
  margin: 30rpx;
  background-color: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.result-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.result-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.result-count {
  font-size: 26rpx;
  color: #999;
}

.char-grid {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 15rpx;
}

.char-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 15rpx;
  background-color: #f5f7fa;
  border-radius: 8rpx;
}

.char-text {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 5rpx;
}

.char-pinyin {
  font-size: 20rpx;
  color: #999;
}

/* 加载状态 */
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 200rpx;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #e6edff;
  border-top: 4rpx solid #4a6bff;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 20rpx;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.loading-text {
  font-size: 26rpx;
  color: #999;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60rpx 0;
}

.empty-image {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 30rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 10rpx;
}

.empty-tips {
  font-size: 24rpx;
  color: #999;
}

/* 提示 */
.tips {
  margin: 30rpx;
  background-color: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.tip-item {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.tip-item:last-child {
  margin-bottom: 0;
}

.tip-icon {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background-color: #e6edff;
  color: #4a6bff;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 24rpx;
  font-style: italic;
  font-weight: bold;
  margin-right: 15rpx;
}

.tip-text {
  font-size: 26rpx;
  color: #666;
  line-height: 1.5;
}
